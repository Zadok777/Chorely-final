# Supabase
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# RevenueCat — must be EXPO_PUBLIC_-prefixed so Expo exposes them to the bundle.
# Leave blank to use RevenueCat's Test Store key (dev). Fill with the real
# appl_… / goog_… SDK keys once the App Store / Play apps exist.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
